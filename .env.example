# Core
SECRET_KEY=change-me-generate-a-long-random-secret
DEBUG=False
SITE_URL=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,backend
FRONTEND_PORT=3000
BACKEND_PORT=8000

# PostgreSQL used by Docker Compose
POSTGRES_DB=finstar
POSTGRES_USER=finstar
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Django database settings inside Docker
DB_ENGINE=django.db.backends.postgresql
DB_NAME=finstar
DB_USER=finstar
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgres://finstar:change-me@db:5432/finstar

# Django web/security settings for local Docker HTTP
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
DJANGO_COLLECTSTATIC=1
DJANGO_MIGRATE=1

# Frontend/API URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
API_BASE_URL=http://backend:8000/api/v1
ADMIN_BACKEND_URL=http://backend:8000/api/v1

# Public company/contact config
NEXT_PUBLIC_COMPANY_EMAIL=
NEXT_PUBLIC_PHONE_NUMBER=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Backend company/contact config
COMPANY_EMAIL=
COMPANY_PHONE=
COMPANY_WHATSAPP_NUMBER=
COMPANY_ADDRESS=
COMPANY_ADDRESS_LINK=
COMPANY_FACEBOOK_URL=
COMPANY_LINKEDIN_URL=

# Email and integrations
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Finstar Sourcing <sales@example.com>
OPENAI_API_KEY=
RESEND_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=finstar
